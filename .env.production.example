# Copy to `.env` on the server (next to docker-compose.yml) and fill in.
# Generate strong values, e.g.:
#   POSTGRES_PASSWORD:  openssl rand -hex 24
#   SESSION_SECRET:     openssl rand -hex 32
POSTGRES_PASSWORD=change-me
SESSION_SECRET=change-me-64-hex-chars

# Почта (подтверждение регистрации, сброс пароля).
# Любой SMTP: Gmail (smtp.gmail.com:587 + app password), Resend (smtp.resend.com:465), и т.д.
# Без SMTP_HOST письма не шлются — ссылки печатаются в лог контейнера (docker logs almanax).
APP_URL=https://almanax.tech
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Almanax <no-reply@almanax.tech>
